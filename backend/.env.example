# Ambiente: development | demo | production
APP_ENV=development

# Banco de dados (Supabase Session Pooler)
DATABASE_URL=postgresql://postgres.SEU_PROJECT_REF:[SUA_SENHA]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# Porta do backend (opcional — padrão 3000)
PORT=3000

# URL do frontend para CORS (opcional — padrão localhost:5173)
FRONTEND_URL=http://localhost:5173

# Chave de criptografia para credenciais (AES-256-GCM — 64 chars hex = 32 bytes)
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OBRIGATÓRIA em production. Em development usa chave padrão com aviso.
ENCRYPTION_KEY=

# api_captcha local (solver próprio — tenta antes do 2captcha para economizar)
CAPTCHA_API_URL=http://localhost:8000
CAPTCHA_API_KEY=dev-key
